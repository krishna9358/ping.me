{
  "name": "better-uptime",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "bun prisma generate --schema packages/store/prisma/schema.prisma",
    "db:migrate": "bun prisma migrate dev --schema packages/store/prisma/schema.prisma",
    "db:deploy": "bun prisma migrate deploy --schema packages/store/prisma/schema.prisma",
    "db:studio": "bun prisma studio --schema packages/store/prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.1.42",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "axios": "^1.9.0"
  }
}
