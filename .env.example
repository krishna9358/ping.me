# ============================================
# Ping.Me — Single root .env for all services
# ============================================
# Copy this file to .env and fill in values.
# All apps and packages read from this single file.

# ---------- PostgreSQL ----------
DATABASE_URL="postgres://postgres:postgres@localhost:5432/pingme"

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379
STREAM_NAME=pingme:website

# ---------- API ----------
PORT=3000
JWT_SECRET=change-me-to-a-random-secret
FRONTEND_ORIGIN=http://localhost:5173

# ---------- Worker ----------
REGION_ID=default
WORKER_ID=worker-1

# ---------- Frontend (Vite) ----------
VITE_API_URL=http://localhost:3000/api/v1

# ---------- Tests ----------
BACKEND_URL=http://localhost:3000/api/v1
